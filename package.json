{
  "name": "design-tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/kardia-ds.umd.js",
  "module": "./dist/kardia-ds.es.js",
  "types": "./dist/types/index.d.ts",
  "style": "./dist/kardia-ds.css",
  "exports": {
    ".": {
      "import": "./dist/kardia-ds.es.js",
      "require": "./dist/kardia-ds.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./styles": "./dist/kardia-ds.css",
    "./dist/css/variables.css": "./dist/css/variables.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly && node sd.config.js",
    "docs:build": "vite build --config vite.docs.config.ts",
    "tokens:extract": "node scripts/extract-tokens.mjs",
    "tokens:build": "node sd.config.js",
    "tokens:sync": "npm run tokens:extract && npm run tokens:build",
    "tokens:watch": "chokidar \"tokens/tokens.json\" -c \"npm run tokens:build\""
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "style-dictionary": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar-cli": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
